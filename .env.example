OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.deepseek.com/v1
MODEL_NAME=deepseek-chat
USE_LLM_SUMMARY=0

# 也可以使用 DeepSeek 风格变量名
# DEEPSEEK_API_KEY=your_api_key_here
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat

# 默认读取该目录下的 .docx / .pdf / .doc 简历
# 旧版 .doc 依赖本机 LibreOffice 或 Microsoft Word 转换
RESUME_DIR=examples\resumes

# 如需手动指定多份简历，可用分号分隔
# RESUME_FILE_PATHS=examples\resumes\resume1.docx;examples\resumes\resume2.pdf

# 可指定岗位 JD 文件；留空时使用 examples\sample_jd.md
JD_FILE_PATH=

# 设置为 debug 可查看 Thought / Action / Observation 调试流程
OUTPUT_MODE=

# Memory/RAG 命名空间，用来区分不同用户或不同求职画像
JOB_FIT_USER_ID=default_user

# SQLite 分析结果数据库路径；留空时使用 sql/job_fit.db
# JOB_FIT_DB_PATH=sql/job_fit.db
